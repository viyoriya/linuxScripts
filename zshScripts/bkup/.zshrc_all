#======================================================================
#============================= System  ================================
#======================================================================
alias wget="wget --hsts-file=$XDG_DATA_HOME/.wget-hsts"
alias dmesg='sudo dmesg -wH'
alias du='du -h --max-depth=1 | sort -hr'
alias lsblk='lsblk -o NAME,FSTYPE,SIZE,MOUNTPOINT,LABEL,UUID'
alias blkid='sudo blkid'
alias fdisk='sudo fdisk -l'
alias parted='sudo parted -l'
alias inxi='inxi -Fxzc0'
alias tree='tree -C'
#alias ls='ls -lahX --color=auto -I "." -I ".." --group-directories-first'
alias ls="eza -la --group-directories-first"
#alias ls="eza -la --group-directories-first --icons=auto"
alias lst='ls -F -lah --color=auto --group-directories-first'
alias grep='grep --color=auto'
alias ncdu='ncdu -x --color dark'
alias cls='printf "\033c"'
alias clss='printf "\033c" && tput civis'
alias diff='diff --color=always --side-by-side '
alias fd='sudo find / -name '
alias gr='sudo grep -iRl'
alias hp='htop -u nobody'

#======================================================================
#============================= git ====================================
#======================================================================
alias gita='git add '
alias gitr='git rm '
alias gitc='git commit -m'
alias gitd='git diff --color-words'
alias gitp="git push origin master"
alias gitpu="git pull origin master"
alias gitl='git log --graph --oneline --decorate'
alias gits='git status -sb'
alias gitsls='git status --porcelain'
alias gitm='git ls-files -m'
alias giti='echo; git log -n 12 --graph --oneline --decorate; echo; git status; echo'
alias gito='git config --get remote.origin.url'
alias gitst='git stash'
#======================================================================
#============================= tmux  ==================================
#======================================================================
alias tm_ks='tmux kill-server'
alias tm_kill='pkill -f tmux'
#======================================================================
#======================== pacman & yay ================================
#======================================================================
alias yayTui='yay -Slq | fzf --multi --preview "yay -Si {1}" | xargs -ro yay -S'
alias pacul='comm -23 <(pacman -Qqett | sort | uniq) <(pacman -Qqg base -g base-devel | sort | uniq)'
alias pacls='grep -i installed /var/log/pacman.log'
alias pacUnlockDB='sudo rm /var/lib/pacman/db.lck' # remove pacman lock
#alias pacCleanup='sudo pacman -Rns $(pacman -Qtdq)'
alias dmenuUpdate='pkill -RTMIN+1 dwmblocks'
alias pacScc='sudo pacman -Scc'
alias pacSyyu='sudo pacman -Syyu && dmenuUpdate'
alias pacSccDel='sudo rm -rf /var/cache/pacman/pkg/download-*(N) && yay -Scc && dmenuUpdate'
#======================================================================
#============================= common  ================================
#======================================================================
alias co='sudo chown -R $USER:$USER '
alias smi='make clean && make && sudo make install'
alias neofetch='/usr/bin/neofetch && python3 $SCRIPTS_PATH/tubescript.py'
#alias rd="redshift -P -O 6800K"
alias tldr='f() { curl cheat.sh/$1; };f'
alias fnvim='nvim -p $(fzf)'
alias fhx='hx $(fzf)'
alias zathura='vj_xdo zathura'
alias feeh='vj_xdo feh'
alias tty-clock='tty-clock -cC 2'

alias proj='cd ~/Documents/GIT_PROJECTS/'
alias proz='cd $SCRIPTS_PATH/zshScripts/'
alias prov='cd ~/Documents/GIT_PROJECTS/viyoriya/'
alias prow='cd ~/Documents/GIT_PROJECTS/wm/'
alias pros='cd ~/Documents/GIT_PROJECTS/wm/suckless/'
alias dwmd='cd ~/Documents/GIT_PROJECTS/wm/suckless/dwm/'

alias vscd="sudo rm /usr/share/applications/codium-wayland.desktop"
alias vsc="sudo sed -i 's/Categories=Utility;Development;IDE;/Categories=TextEditor;Development;IDE;/' /usr/share/applications/codium.desktop"
