#export CLICOLOR=1

export GPG_TTY=$(tty)
#export GPG_TTY=$TTY
export XDG_CONFIG_HOME=$HOME/.config
export XDG_DATA_HOME=$HOME/.local/share
export XDG_STATE_HOME=$HOME/.local/state
export XDG_CACHE_HOME=$HOME/.cache

export PASSWORD_STORE_DIR="$XDG_DATA_HOME"/.password-store
export PASSWORD_STORE_CLIP_TIME=15
export PASSWORD_STORE_X_SELECTION="clipboard"

export ZDOTDIR="$XDG_CONFIG_HOME"/zsh
export GREP_COLOR="mt=1;32"

SCRIPTS_PATH="$HOME/Documents/GIT_PROJECTS/viyoriya/linuxScripts"
ZSCRIPT_PATH="$SCRIPTS_PATH/zshScripts/.zshrc_all"

#======================================================================
#============================= for TTY ================================
export PS1="%F{blue}%~%B%F{red} >>%F{reset}%b "
#======================================================================
#ZPS1="%b %{$fg[blue]%}%~%{$fg[green]%} %{$reset_color%}%b "
#ZPS1="%F{blue}%~%B%F{red} %F{reset}%b "
ZPS1="%F{blue}%~%B%F{red} >>%F{reset}%b "

if [[ "$TERM" = "linux" || "$TERM" = "screen" ]]; then
  #    export PS1=" \[\e[34m\]\w\[\e[m\] \[\e[31m\]>\[\e[m\]\[\e[31m\]>\[\e[m\] "
  export PS1="%F{blue}%~%B%F{red} >>%F{reset}%b "
  source $SCRIPTS_PATH/zshScripts/tty-black.sh
fi

alias lsalias='GREP_COLORS="ms=32" grep --color=always -E "^alias " "$ZSCRIPT_PATH"'
alias lsgit='GREP_COLORS="ms=34" grep --color=always -E "^alias git" "$ZSCRIPT_PATH"'
alias lspac='GREP_COLORS="ms=35" grep --color=always -E "^alias pac" "$ZSCRIPT_PATH"'
alias lstmux='GREP_COLORS="ms=34" grep --color=always -E "^alias tm_" "$ZSCRIPT_PATH"'
#alias lsfunc='declare -F | grep 'vj_''
#alias lsfuncName='compgen -A function | grep 'vj_''

#======================================================================
#============================= Function's =============================
#======================================================================

lspath() { tr ':' '\n' <<<"$PATH"; }
up() { cd $(printf "%0.s../" {1..${1:-1}}); }

vj_xdo() {
  local id=$(xdo id)
  xdo hide "$id"
  "$@" >/dev/null 2>&1
  xdo show "$id"
}

